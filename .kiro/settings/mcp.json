{
  "mcpServers": {
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=eu-north-1"
      ],
      "timeout": 100000
    },
    "cainban": {
      "command": "cainban",
      "args": [
        "mcp"
      ]
    },
    "aws-pricing-calculator": {
      "command": "node",
      "args": [
        "${HOME}/git/sample-aws-pricing-calculator-mcp/mcp-server.js"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "headroom": {
      "command": "headroom",
      "args": [
        "mcp",
        "serve"
      ],
      "env": {},
      "autoApprove": [
        "headroom_compress",
        "headroom_retrieve"
      ]
    }
  }
}
